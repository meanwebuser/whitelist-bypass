# VK community access token (required). Settings -> API usage -> Access tokens.
VK_TOKEN=vk1.a.your-community-access-token

# VK community ID, digits only (required).
VK_GROUP_ID=123456789

# Comma-separated VK user IDs allowed to issue commands. Empty = anyone.
VK_USER_IDS=

# Resource mode passed to spawned creators: default | moderate | unlimited.
RESOURCES=default

# Optional: route the joiner's egress through a local SOCKS5 proxy (a VPN client),
# so traffic exits via your VPS instead of this machine's IP. Forwarded to every
# spawned creator. Inside the container 127.0.0.1 is the CONTAINER, not the host -
# point at host.docker.internal (uncomment extra_hosts in docker-compose.yml) or a
# sidecar service name. The SOCKS5 inbound must support UDP ASSOCIATE.
UPSTREAM_SOCKS=
UPSTREAM_USER=
UPSTREAM_PASS=
